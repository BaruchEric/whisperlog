# Core
UX570_ARCHIVE_DIR=~/Documents/ux570-archive
UX570_STATE_DIR=~/.ux570

# Whisper (always local)
WHISPER_MODEL=small.en
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
ENABLE_VAD=true
WHISPER_LANGUAGE=en

# Concurrency (watch daemon)
MAX_CONCURRENT_TRANSCRIPTIONS=1

# Enrichment
DEFAULT_ENRICH_BACKEND=ollama   # ollama | claude-api | claude-cli
DEFAULT_ENRICH_TASK=summarize

# Ollama (local)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT_SECS=180

# Claude API (optional - key stored in OS keychain via `ux570 config set-key anthropic`, NEVER here)
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_AGENT_MODEL=claude-opus-4-7
CLAUDE_FALLBACK_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096
MAX_DAILY_CLAUDE_USD=5.00
COST_CONFIRM_USD=0.10

# Claude Code CLI (optional)
CLAUDE_CLI_PATH=claude
